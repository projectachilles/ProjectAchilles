{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/jimx/F0RT1KA/ProjectAchilles && ./scripts/hooks/validate-commit-msg.sh",
            "timeout": 5,
            "statusMessage": "Validating commit message..."
          },
          {
            "type": "command",
            "command": "cd /home/jimx/F0RT1KA/ProjectAchilles && ./scripts/hooks/validate-branch-name.sh",
            "timeout": 5,
            "statusMessage": "Checking branch name..."
          },
          {
            "type": "command",
            "command": "cd /home/jimx/F0RT1KA/ProjectAchilles && ./scripts/hooks/validate-tag-push.sh",
            "timeout": 10,
            "statusMessage": "Validating tag consistency..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/jimx/F0RT1KA/ProjectAchilles && ./scripts/hooks/changelog-reminder.sh",
            "timeout": 5,
            "statusMessage": "Checking changelog..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel 2>/dev/null || echo /home/jimx/F0RT1KA/ProjectAchilles) && ./scripts/check-docs-drift.sh",
            "timeout": 10,
            "statusMessage": "Checking for documentation drift..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "static-analysis@trailofbits": true,
    "fix-review@trailofbits": true,
    "differential-review@trailofbits": true,
    "semgrep-rule-creator@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "insecure-defaults@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "audit-context-building@trailofbits": true
  }
}

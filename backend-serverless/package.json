{
  "name": "project-achilles-backend-serverless",
  "version": "2.0.0",
  "description": "ProjectAchilles - Serverless Backend for Vercel",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "vercel-build": "REPO_URL=\"${TESTS_REPO_URL:-https://github.com/ubercylon8/f0_library.git}\"; if [ -n \"$REPO_URL\" ]; then rm -rf data/f0_library && if [ -n \"$GITHUB_TOKEN\" ]; then CLONE_URL=\"https://x-access-token:${GITHUB_TOKEN}@${REPO_URL#https://}\"; else CLONE_URL=\"$REPO_URL\"; fi && git clone --depth 1 \"$CLONE_URL\" data/f0_library; fi && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clerk/backend": "^2.33.6",
    "@clerk/express": "^1.7.82",
    "@elastic/elasticsearch": "^8.19.2",
    "@libsql/client": "^0.17.4",
    "@vercel/blob": "^2.6.1",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "node-forge": "^1.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "qs": "^6.15.2",
    "js-cookie": "^3.0.7",
    "ws@>=8.0.0 <8.21.0": "8.21.0",
    "path-to-regexp@>=4.0.0 <6.3.0": "6.3.0",
    "undici@<6.27.0": "6.27.0",
    "tar@<=7.5.15": "7.5.19",
    "form-data@>=4.0.0 <4.0.6": "4.0.6",
    "@opentelemetry/core@<2.8.0": "2.8.0",
    "esbuild@>=0.27.3 <0.28.1": "0.28.1",
    "js-yaml@>=4.0.0 <4.2.0": "4.2.0",
    "minimatch@>=10.0.0 <10.2.3": "10.2.4",
    "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
    "smol-toml@<1.6.1": "1.6.1",
    "brace-expansion@>=5.0.0 <5.0.6": "5.0.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.20.1",
    "@types/node-forge": "^1.3.14",
    "@types/supertest": "^6.0.3",
    "@vercel/node": "^5.8.26",
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}

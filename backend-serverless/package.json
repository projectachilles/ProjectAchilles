{
  "name": "project-achilles-backend-serverless",
  "version": "1.0.0",
  "description": "ProjectAchilles - Serverless Backend for Vercel",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "vercel-build": "if [ -n \"$TESTS_REPO_URL\" ]; then rm -rf data/f0_library && git clone --depth 1 \"https://x-access-token:${GITHUB_TOKEN}@${TESTS_REPO_URL#https://}\" data/f0_library; fi && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clerk/backend": "^2.31.0",
    "@clerk/express": "^1.7.70",
    "@elastic/elasticsearch": "^8.19.1",
    "@libsql/client": "^0.14.0",
    "@vercel/blob": "^0.27.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "overrides": {
    "qs": "6.14.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@vercel/node": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

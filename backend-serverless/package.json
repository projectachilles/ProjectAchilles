{
  "name": "project-achilles-backend-serverless",
  "version": "2.0.0",
  "description": "ProjectAchilles - Serverless Backend for Vercel",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "vercel-build": "REPO_URL=\"${TESTS_REPO_URL:-https://github.com/ubercylon8/f0_library.git}\"; if [ -n \"$REPO_URL\" ]; then rm -rf data/f0_library && if [ -n \"$GITHUB_TOKEN\" ]; then CLONE_URL=\"https://x-access-token:${GITHUB_TOKEN}@${REPO_URL#https://}\"; else CLONE_URL=\"$REPO_URL\"; fi && git clone --depth 1 \"$CLONE_URL\" data/f0_library; fi && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clerk/backend": "^2.33.3",
    "@clerk/express": "^1.7.79",
    "@elastic/elasticsearch": "^8.19.1",
    "@libsql/client": "^0.17.3",
    "@vercel/blob": "^2.3.3",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "overrides": {
    "qs": "6.14.2",
    "path-to-regexp@>=4.0.0 <6.3.0": "6.3.0",
    "undici@<6.24.0": "6.24.1",
    "tar@<=7.5.10": "7.5.11",
    "minimatch@>=10.0.0 <10.2.3": "10.2.4",
    "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
    "smol-toml@<1.6.1": "1.6.1",
    "brace-expansion@<5.0.5": "5.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.7.0",
    "@types/node-forge": "^1.3.14",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@vercel/node": "^5.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}

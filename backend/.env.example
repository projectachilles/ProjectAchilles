# ProjectAchilles Backend Configuration

# Clerk Authentication (get from https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=change-me-to-a-secure-random-string

# CORS
CORS_ORIGIN=http://localhost:5173

# ============ Test Repository Configuration ============
# Option 1: Git Sync (recommended for production)
# If TESTS_REPO_URL is set, tests will be synced from the GitHub repository

# GitHub repository URL (required for Git sync)
TESTS_REPO_URL=https://github.com/ubercylon8/f0_library.git

# Branch to sync from (default: main)
TESTS_REPO_BRANCH=main

# Local path to clone the repository (default: ./data/f0_library)
TESTS_LOCAL_PATH=./data/f0_library

# GitHub Personal Access Token (required for private repositories)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=ghp_xxxxx

# Option 2: Local Path (fallback if TESTS_REPO_URL is not set)
# Direct path to tests_source directory
TESTS_SOURCE_PATH=../../f0_library/tests_source

# =============================================================================
# ProjectAchilles Backend Configuration
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
# Or run the interactive wizard:         ./setup.sh

# ======================== Authentication (required) ==========================
# Get keys from https://dashboard.clerk.com → Your App → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ======================== Server =============================================
PORT=3000
NODE_ENV=development

# ======================== Secrets ============================================
# Session signing key (generate: openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-secure-random-string

# Encryption key for settings at rest (analytics credentials, cert passwords)
# Required for Docker/PaaS where hostname is not stable across restarts
# If not set, falls back to machine-derived key (hostname + username)
# ENCRYPTION_SECRET=change-me-to-a-secure-random-string

# ======================== CORS ===============================================
# For Docker:       http://localhost
# For local dev:    http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ======================== Agent Communication ================================
# External URL for agent communication (used in enrollment commands)
# Set for ngrok, tunnels, or production deployments
AGENT_SERVER_URL=https://achilles-agent.ngrok.app

# ======================== Tunnel (for ./start.sh --tunnel) ===================
# Requires ngrok paid plan — get domains at: https://dashboard.ngrok.com/domains
NGROK_FRONTEND_DOMAIN=projectachilles.ngrok.app
NGROK_BACKEND_DOMAIN=achilles-agent.ngrok.app

# ======================== Test Repository ====================================
# Git-synced repository (recommended for production)
TESTS_REPO_URL=https://github.com/projectachilles/f0_library.git
TESTS_REPO_BRANCH=main
TESTS_LOCAL_PATH=./data/f0_library

# GitHub Personal Access Token (required for private repos)
# Generate at: https://github.com/settings/tokens — scopes: repo
GITHUB_TOKEN=ghp_xxxxx

# Fallback: direct path if TESTS_REPO_URL is not set
TESTS_SOURCE_PATH=../../f0_library/tests_source

# ======================== Agent Repository ====================================
# Git-synced agent source (required for Railway — the agent/ dir is not in the Docker image)
# AGENT_REPO_URL=https://github.com/projectachilles/ProjectAchilles.git
# AGENT_REPO_BRANCH=main
# AGENT_LOCAL_PATH=./data/agent-source
#
# Fallback: direct path if AGENT_REPO_URL is not set
# AGENT_SOURCE_PATH=../../agent

# ======================== Elasticsearch (Analytics) ==========================
# Environment variables override file-based config (~/.projectachilles/analytics.json)
# Choose ONE of the three options below.

# --- Option 1: Local Docker instance (via docker compose --profile elasticsearch)
# ELASTICSEARCH_NODE=http://elasticsearch:9200
# ELASTICSEARCH_INDEX_PATTERN=achilles-results-*

# --- Option 2: Elastic Cloud
# ELASTICSEARCH_CLOUD_ID=my-deployment:dXMtY2VudHJhbDEuZ2NwLmNsb3VkLmVzLmlvJGFiY2QxMjM0
# ELASTICSEARCH_API_KEY=base64_encoded_api_key

# --- Option 3: Self-hosted / Direct connection
# ELASTICSEARCH_NODE=https://your-es-host:9200
# ELASTICSEARCH_API_KEY=base64_encoded_api_key
# Or use basic auth instead of API key:
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

# Index pattern for analytics queries (default: achilles-results-*)
# ELASTICSEARCH_INDEX_PATTERN=achilles-results-*

# ======================== Railway.app Deployment ==============================
# Set these in the Railway dashboard (Settings → Variables), not in a .env file.
# See RAILWAY.md for the full deployment walkthrough.
#
# Required (backend service):
#   CLERK_PUBLISHABLE_KEY    — same as above
#   CLERK_SECRET_KEY         — same as above
#   SESSION_SECRET           — generate: openssl rand -base64 32
#   ENCRYPTION_SECRET        — generate: openssl rand -base64 32 (REQUIRED on Railway)
#   CORS_ORIGIN              — https://<your-frontend>.up.railway.app
#   AGENT_SERVER_URL         — https://<your-backend>.up.railway.app
#   NODE_ENV                 — production
#   TESTS_REPO_URL           — https://github.com/your-org/f0_library.git
#   AGENT_REPO_URL           — https://github.com/your-org/ProjectAchilles.git (for agent builds)
#   GITHUB_TOKEN             — PAT with repo scope (for private repos)
#
# Elastic Cloud:
#   ELASTICSEARCH_CLOUD_ID   — from Elastic Cloud console
#   ELASTICSEARCH_API_KEY    — from Elastic Cloud console
#
# Required (frontend service):
#   CLERK_PUBLISHABLE_KEY    — same publishable key
#   BACKEND_HOST             — backend.railway.internal
#   BACKEND_PORT             — 3000 (default, usually omit)

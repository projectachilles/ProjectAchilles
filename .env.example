# ProjectAchilles - Docker Environment Configuration
# Copy this file to .env and customize for your deployment
#
# These values override docker-compose.yml defaults
# For standalone (./start.sh), use backend/.env instead

# ============ CORS Configuration ============
# Set to your frontend URL when using tunnels or custom domains
# Default: http://localhost (for local Docker deployment)
# CORS_ORIGIN=https://your-frontend.ngrok.app

# ============ Agent Configuration ============
# External URL where agents connect to the backend
# Required when using ngrok or deploying to a public URL
# AGENT_SERVER_URL=https://your-backend.ngrok.app

# ============ Tunnel Domains (for ./start.sh --tunnel) ============
# These are used by start.sh, not Docker
# NGROK_FRONTEND_DOMAIN=your-app.ngrok.app
# NGROK_BACKEND_DOMAIN=your-api.ngrok.app

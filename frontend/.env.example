# Clerk Authentication
# Get your keys from: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# API Configuration (optional)
# Backend API URL — leave empty for local dev (Vite proxy handles /api requests)
# Only set this for direct mode (Docker, PaaS) where there's no Vite proxy
# VITE_API_URL=http://localhost:3000

# Backend port (for Vite proxy configuration)
VITE_BACKEND_PORT=3000
